# Server (optional — defaults shown)
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=*

# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk authentication (required)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
# Optional — PEM public key for offline JWT verification (faster, no network call to Clerk)
CLERK_JWT_KEY=your_clerk_public_jwt_key_pem_here
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_clerk_webhook_signing_secret_here

# Billing — Mobbex (required if billing module is used)
BILLING_PROVIDER=mobbex
MOBBEX_API_KEY=your_mobbex_api_key_here
MOBBEX_ACCESS_TOKEN=your_mobbex_access_token_here
MOBBEX_WEBHOOK_SECRET=your_mobbex_webhook_secret_here
MOBBEX_TEST_MODE=true
MOBBEX_TIMEOUT_MS=10000

# Subscriptions (optional — defaults shown)
SIGNUP_MODE=freemium
FREE_TRIAL_DAYS=14
STRICT_ENTITLEMENTS_ON_PAST_DUE=false
