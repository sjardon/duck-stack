# Clerk authentication (required)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Server configuration (optional — defaults shown)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# CORS allowed origin (optional)
